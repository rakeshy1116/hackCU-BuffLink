# Copy this file to .env and fill in your values
# Never commit .env to version control

# AWS Configuration
AWS_REGION=us-east-2

# Gmail SMTP Configuration
SENDER_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# Flask Configuration
# Comma-separated list of allowed CORS origins (e.g., chrome-extension://your-extension-id)
ALLOWED_ORIGINS=*
FLASK_DEBUG=false
FLASK_PORT=5007

# Public base URL of the Flask API (used for unsubscribe links in emails)
API_BASE_URL=http://127.0.0.1:5007

# Scheduler Configuration
# How often (in hours) to scrape the CU Boulder calendar for new events (default: 6)
SCRAPE_INTERVAL_HOURS=6
